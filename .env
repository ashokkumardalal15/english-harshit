# You do NOT create a .env file for Vercel deployment itself - env vars are added
# in the Vercel dashboard (Project → Settings → Environment Variables) instead.
# This file is just here to show you which names to use there.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

ANTHROPIC_API_KEY=

OPENAI_API_KEY=
